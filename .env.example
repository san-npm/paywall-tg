# Get from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Secret token for webhook verification (generate a random string)
WEBHOOK_SECRET=your_random_secret_here

# Your deployed URL (set after Vercel deploy)
WEBAPP_URL=https://your-app.vercel.app

# Turso database (https://turso.tech)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Webmaster verification tokens (optional)
# Google Search Console HTML tag content
GSC_VERIFICATION=
# Bing Webmaster Tools meta tag (msvalidate.01)
BING_VERIFICATION=
# Yandex Webmaster meta tag
YANDEX_VERIFICATION=

# Telegram WebApp init_data max age in seconds (anti-replay window, default: 900)
INIT_DATA_MAX_AGE_SECONDS=900

# Optional comma-separated Telegram user IDs allowed to use admin commands
# (/admin_disable <product_id>, /admin_enable <product_id>) and /api/admin actions
ADMIN_TELEGRAM_IDS=

# Replay-protection table retention and cleanup sampling for Telegram update_id idempotency
PROCESSED_UPDATES_TTL_DAYS=3
PROCESSED_UPDATES_CLEANUP_RATE=0.05
