# Get from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Secret token for webhook verification (generate a random string)
WEBHOOK_SECRET=your_random_secret_here

# Your deployed URL (set after Vercel deploy)
WEBAPP_URL=https://your-app.vercel.app

# Turso database (https://turso.tech)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# Telegram WebApp init_data max age in seconds (anti-replay window, default: 900)
INIT_DATA_MAX_AGE_SECONDS=900
